[init]
	defaultBranch = main
[pull]
	ff = only
	rebase = true
[push]
	default = current
	autoSetupRemote = true
	followTags = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[help]
	autocorrect = prompt
[core]
	pager = less -FRX
	attributesfile = ~/.gitattributes
	excludesfile = ~/.gitignore
[tag]
	sort = version:refname
[diff]
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
[branch]
	sort = -committerdate
[column]
	ui = auto
[commit]
	# gpgsign = true
	verbose = true

# Mergiraf setup - https://mergiraf.org/usage.html#registration-as-a-git-merge-driver
# Also needs config in .gitattributes
[merge "mergiraf"]
    name = mergiraf
    driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[alias]
	# ATTENTION: All aliases prefixed with ! run in /bin/sh make sure you use sh syntax, not bash/zsh or whatever
	# Shows recent branches sorted by date. Takes 2 optional arguments - branch (defaults to main), count (defaults to 20)
	recentb = "!r() { refbranch=$1 count=$2; git for-each-ref --sort=-committerdate refs/heads --format='%(refname:short)|%(HEAD)%(color:yellow)%(refname:short)|%(color:bold green)%(committerdate:relative)|%(color:blue)%(subject)|%(color:magenta)%(authorname)%(color:reset)' --color=always --count=${count:-20} | while read line; do branch=$(echo \"$line\" | awk 'BEGIN { FS = \"|\" }; { print $1 }' | tr -d '*'); ahead=$(git rev-list --count \"${refbranch:-origin/main}..${branch}\"); behind=$(git rev-list --count \"${branch}..${refbranch:-origin/main}\"); colorline=$(echo \"$line\" | sed 's/^[^|]*|//'); echo \"$ahead|$behind|$colorline\" | awk -F'|' -vOFS='|' '{$5=substr($5,1,70)}1' ; done | ( echo \"ahead|behind||branch|lastcommit|message|author\\n\" && cat) | column -ts'|';}; r"
	alias = config --get-regexp ^alias\\.
	logs = log --show-signature
	cis = commit -S

[includeIf "gitdir:/Users/willemsb/"]
	path = ~/.config/private/work.gitconfig
